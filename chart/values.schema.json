              "default": 80
            },
            "targetMemoryUtilizationPercentage": {
              "type": "integer",
              "title": "Target memory utilization percentage"
            }
          }
        },
        "volumes": {
          "type": "array",
          "title": "Additional volumes",
          "default": [],
          "items": {
            "type": "object"
          }
        },
        "volumeMounts": {
