        "fullnameOverride": {
          "type": "string",
          "title": "Fullname override",
          "default": ""
        },
        "autoscaling": {
          "type": "object",
          "title": "Autoscaling",
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean",
              "title": "Enable autoscaling",
              "default": false
            },
            "minReplicas": {
              "type": "integer",
              "title": "Minimum replicas",
              "default": 1
            },
            "maxReplicas": {
              "type": "integer",
              "title": "Maximum replicas",
              "default": 100
            },
            "targetCPUUtilizationPercentage": {
