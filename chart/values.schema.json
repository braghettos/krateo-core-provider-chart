            "minReplicas": {
              "type": "integer",
              "title": "Minimum replicas",
              "default": 1
            },
            "maxReplicas": {
              "type": "integer",
              "title": "Maximum replicas",
              "default": 100
            },
            "targetCPUUtilizationPercentage": {
              "type": "integer",
