{
  "$schema": "http://json-schema.org/draft-07/schema",
  "type": "object",
  "title": "CoreProvider",
  "description": "Full-coverage values schema for the Krateo core-provider chart, pinned to installer 2.7.0 / chart 0.35.2 (appVersion 0.26.1).",
  "additionalProperties": false,
  "properties": {
    "replicaCount": {
      "type": "integer",
      "title": "Replica count",
      "default": 1
    },
    "image": {
      "type": "object",
      "title": "Image",
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "title": "Image repository",
          "default": "ghcr.io/krateoplatformops/core-provider"
        },
        "pullPolicy": {
          "type": "string",
          "title": "Image pull policy",
          "enum": [
            "IfNotPresent",
            "Always",
            "Never"
          ],
          "default": "IfNotPresent"
        },
        "tag": {
          "type": "string",
          "title": "Image tag",
          "description": "Overrides the image tag whose default is the chart appVersion.",
          "default": ""
        }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "title": "Image pull secrets",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "nameOverride": {
      "type": "string",
      "title": "Name override",
      "default": ""
    },
    "fullnameOverride": {
      "type": "string",
      "title": "Fullname override",
      "default": ""
    },
    "serviceAccount": {
      "type": "object",
      "title": "Service account",
      "additionalProperties": false,
      "properties": {
        "create": {
          "type": "boolean",
          "title": "Create service account",
          "default": true
        },
        "automount": {
          "type": "boolean",
          "title": "Automount service account token",
          "default": true
        },
        "annotations": {
          "type": "object",
          "title": "Service account annotations",
          "default": {}
        },
        "name": {
          "type": "string",
          "title": "Service account name",
          "default": ""
        }
      }
    },
    "podAnnotations": {
      "type": "object",
      "title": "Pod annotations",
      "default": {}
    },
    "podLabels": {
      "type": "object",
      "title": "Pod labels",
      "default": {}
    },
    "podSecurityContext": {
      "type": "object",
      "title": "Pod security context",
      "default": {}
    },
    "securityContext": {
      "type": "object",
      "title": "Container security context",
      "default": {}
    },
    "service": {
      "type": "object",
      "title": "Service",
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "title": "Service type",
          "enum": [
            "ClusterIP",
            "NodePort",
            "LoadBalancer"
          ],
          "default": "ClusterIP"
        },
        "port": {
          "type": "integer",
          "title": "Service port",
          "default": 80
        }
      }
    },
    "ingress": {
      "type": "object",
      "title": "Ingress",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Enable ingress",
          "default": false
        },
        "className": {
          "type": "string",
          "title": "Ingress class name",
          "default": ""
        },
        "annotations": {
          "type": "object",
          "title": "Ingress annotations",
          "default": {}
        },
        "hosts": {
          "type": "array",
          "title": "Ingress hosts",
          "items": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string"
              },
              "paths": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "type": "string"
                    },
                    "pathType": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "default": [
            {
              "host": "chart-example.local",
              "paths": [
                {
                  "path": "/",
                  "pathType": "ImplementationSpecific"
                }
              ]
            }
          ]
        },
        "tls": {
          "type": "array",
          "title": "Ingress TLS",
          "default": [],
          "items": {
            "type": "object"
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "title": "Resources",
      "default": {}
    },
    "autoscaling": {
      "type": "object",
      "title": "Autoscaling",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "title": "Enable autoscaling",
          "default": false
        },
        "minReplicas": {
          "type": "integer",
          "title": "Minimum replicas",
          "default": 1
        },
        "maxReplicas": {
          "type": "integer",
          "title": "Maximum replicas",
          "default": 100
        },
        "targetCPUUtilizationPercentage": {
          "type": "integer",
          "title": "Target CPU utilization percentage",
          "default": 80
        },
        "targetMemoryUtilizationPercentage": {
          "type": "integer",
          "title": "Target memory utilization percentage"
        }
      }
    },
    "volumes": {
      "type": "array",
      "title": "Additional volumes",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "volumeMounts": {
      "type": "array",
      "title": "Additional volume mounts",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "nodeSelector": {
      "type": "object",
      "title": "Node selector",
      "default": {}
    },
    "tolerations": {
      "type": "array",
      "title": "Tolerations",
      "default": [],
      "items": {
        "type": "object"
      }
    },
    "affinity": {
      "type": "object",
      "title": "Affinity",
      "default": {}
    },
    "env": {
      "type": "object",
      "title": "Environment variables",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "CORE_PROVIDER_DEBUG": {
          "type": "string",
          "title": "Core provider debug",
          "default": "false"
        }
      },
      "default": {
        "CORE_PROVIDER_DEBUG": "false"
      }
    },
    "chartInspector": {
      "type": "object",
      "title": "Chart inspector",
      "additionalProperties": false,
