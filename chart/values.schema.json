              "type": "string",
              "title": "Image pull policy",
              "enum": [
                "IfNotPresent",
                "Always",
                "Never"
              ],
              "default": "IfNotPresent"
            },
            "tag": {
              "type": "string",
              "title": "Image tag",
              "default": "0.2.0"
            }
          }
        },
        "replicaCount": {
          "type": "integer",
          "title": "Replica count",
          "default": 1
        },
        "imagePullSecrets": {
          "type": "array",
          "title": "Image pull secrets",
