          "properties": {
            "create": {
              "type": "boolean",
              "title": "Create service account",
              "default": true
            },
            "automount": {
              "type": "boolean",
              "title": "Automount service account token",
              "default": true
            },
            "annotations": {
              "type": "object",
              "title": "Service account annotations",
              "default": {}
            },
            "name": {
              "type": "string",
              "title": "Service account name",
              "default": ""
            }
          }
        },
        "service": {
          "type": "object",
          "title": "Service",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "title": "Service type",
              "enum": [
                "ClusterIP",
                "NodePort",
                "LoadBalancer"
              ],
              "default": "ClusterIP"
            },
            "port": {
              "type": "integer",
              "title": "Service port",
              "default": 80
            }
          }
        },
        "env": {
          "type": "object",
          "title": "Environment variables",
          "additionalProperties": {
            "type": "string"
          },
          "properties": {
            "HOME": {
              "type": "string",
              "title": "HOME directory",
              "default": "/tmp"
            }
          },
          "default": {
            "HOME": "/tmp"
          }
        },
        "resources": {
          "type": "object",
          "title": "Resources",
          "default": {}
        }
      }
    },
    "cdc": {
